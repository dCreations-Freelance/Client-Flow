APP_NAME=ClientFlow
APP_ENV=local
APP_KEY=
# true solo en local; false en staging y produccion para no exponer
# stack traces ni variables de entorno en las paginas de error.
APP_DEBUG=false
APP_URL=http://localhost:8080

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
# "debug" solo en entorno local; "warning" es el minimo seguro para
# no filtrar PII ni payloads en produccion. Auditado en M-04.
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=clientflow
DB_USERNAME=clientflow
DB_PASSWORD=clientflow

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
VITE_DEV_SERVER_URL=http://localhost:5173

# ---------------------------------------------------------------------------
# IA para el cliente (fase 7)
# ---------------------------------------------------------------------------
# Las API keys reales NO van en el .env: se guardan cifradas en la tabla
# `ai_configs`. Estos valores son solo defaults operacionales y la URL del
# provider OpenAI-compatible (LM Studio, Ollama, vLLM, proxy corporativo).

OPENAI_DEFAULT_MODEL=gpt-4o-mini
ANTHROPIC_DEFAULT_MODEL=claude-3-5-haiku-latest
# Opencode Zen: API OpenAI-compatible con namespace de modelos `opencode-go/`.
# La API key se genera en https://opencode.ai/zen (formato habitual Bearer token).
OPENCODE_BASE_URL=https://opencode.ai/zen/go
OPENCODE_DEFAULT_MODEL=opencode-go/kimi-k2.6

AI_MAX_MESSAGES_PER_HOUR=20
AI_MAX_SESSIONS_PER_DAY=10

AI_HTTP_TIMEOUT=30
AI_HTTP_CONNECT_TIMEOUT=10
